{"openapi":"3.0.0","info":{"title":"Wamify - API Documentation","description":"Powered by RFC Zeralink\n\n© 2009 - 2026 Rezza Flamingo Computer","version":"1.0.0"},"components":{"securitySchemes":{"bearerAuth":{"type":"http","scheme":"bearer","description":"Enter the Bearer Token generated from the API Manager."}},"schemas":{}},"paths":{"/api/v1/sessions":{"get":{"summary":"Get All Sessions","tags":["Sessions"],"description":"Returns all WhatsApp sessions belonging to the authenticated user, including their current status and connection state.","security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"data":{"type":"array"}}}}}}}},"post":{"summary":"Create a New Session","tags":["Sessions"],"description":"Creates a new WhatsApp session. After creation, call `POST /api/v1/sessions/:id/start` to initiate the connection.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","required":["name"],"additionalProperties":false,"properties":{"name":{"type":"string","description":"A descriptive name for the session.","example":"My WA Session"},"history_sync":{"type":"string","enum":["Y","N"],"default":"N","description":"Enable WhatsApp message history sync (Y/N).","example":"N"}}}}}},"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"data":{"type":"object","properties":{"id":{"type":"string"},"name":{"type":"string"},"status":{"type":"string"}}}}}}}}}}},"/api/v1/sessions/{id}/start":{"post":{"summary":"Start Session Connection (QR / Pairing Code)","tags":["Sessions"],"description":"Initiates a WhatsApp connection for the given session. Use `method: 'qr'` (default) to generate a QR code image, or `method: 'pairing'` to link via phone number. After calling this endpoint, poll `GET /api/v1/sessions/:id/status` to retrieve the QR image (`qr` field, base64 PNG) or pairing code.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"properties":{"method":{"type":"string","enum":["qr","pairing"],"default":"qr","description":"Connection method. Use `qr` (default) to scan a QR code, or `pairing` to link via phone number pairing code.","example":"qr"},"phoneNumber":{"type":"string","nullable":true,"description":"Phone number in international format (no '+' or spaces). **Only required when `method` is `pairing`**. Leave empty or omit for QR method.","example":"628123456789"}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"id","required":true,"description":"Session ID"}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"data":{"type":"object","properties":{"id":{"type":"string"},"method":{"type":"string"}}}}}}}}}}},"/api/v1/sessions/{id}/status":{"get":{"summary":"Get Session Status (Polling)","tags":["Sessions"],"description":"Returns the current status of a session. Poll this endpoint after calling `/start`. When status is `qr_ready`, the `qr` field contains a base64 PNG image ready to render. When status is `pairing_ready`, the `pairingCode` field contains the code to enter in WhatsApp. Stop polling once `status` is `connected`.","parameters":[{"schema":{"type":"string"},"in":"path","name":"id","required":true,"description":"Session ID"}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"data":{"type":"object","properties":{"id":{"type":"string"},"name":{"type":"string"},"status":{"type":"string","description":"Session status. Possible values: waiting, qr_ready, pairing, pairing_ready, connecting, connected, syncing, disconnected, reconnecting, failed, paused.","example":"qr_ready"},"qr":{"type":"string","nullable":true,"description":"QR code as a base64 PNG (`data:image/png;base64,...`). Use directly in `<img src>`. Available when status is `qr_ready`.","example":"data:image/png;base64,iVBORw0KGgo..."},"pairingCode":{"type":"string","nullable":true,"description":"Pairing code. Available when status is `pairing_ready`. Enter this code in WhatsApp > Linked Devices > Link with phone number.","example":"RFCAB12"},"phoneNumber":{"type":"string","nullable":true,"description":"Phone number linked to the session. Available after the session is connected.","example":"628123456789"},"active":{"type":"string","enum":["Y","N"],"description":"Whether the session is active.","example":"Y"}}}}}}}}}}},"/api/v1/sessions/{id}/reconnect":{"post":{"summary":"Reconnect Session","tags":["Sessions"],"description":"Reconnects a session that already has a valid auth state (was previously connected and scanned). Use this to recover a disconnected session without re-scanning the QR code. Returns 400 if auth state is missing — user must call `/start` again.","parameters":[{"schema":{"type":"string"},"in":"path","name":"id","required":true,"description":"Session ID"}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"data":{"type":"object","properties":{"id":{"type":"string"},"name":{"type":"string"},"status":{"type":"string"}}}}}}}}}}},"/api/v1/sessions/{id}":{"delete":{"summary":"Delete Session","tags":["Sessions"],"description":"Permanently deletes a session, logs out from WhatsApp, and removes all related data. This action cannot be undone.","parameters":[{"schema":{"type":"string"},"in":"path","name":"id","required":true,"description":"Session ID"}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"}}}}}}}}},"/api/v1/{sessionId}/messages/send/text":{"post":{"summary":"Send Text Message","tags":["Message Sends (Basic)"],"description":"Sends a plain text message to one or more recipients. Supports @all or @628xxx mention syntax in groups.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","text"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"text":{"type":"string","description":"Message body. Use @all to mention everyone in a group, or @628xxx to mention specific recipients.","example":"Hello @628123456789 or @all, this is a message from Wamify."}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/media":{"post":{"summary":"Send Media Message","tags":["Message Sends (Media)"],"description":"Sends an image or video message from a URL. Supports an optional caption with mention syntax, and View Once mode.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","url"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"url":{"type":"string","example":"https://placehold.co/600x400.png"},"caption":{"type":"string","description":"Caption for the media. Use @all to mention everyone in a group, or @628xxx to mention specific recipients.","example":"Wamify - High Performance Messaging Solution @all"},"viewOnceMedia":{"type":"string","enum":["Y","N"],"default":"N","description":"Set to 'Y' to send as View Once media","example":"N"}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/album":{"post":{"summary":"Send Album Message","tags":["Message Sends (Media)"],"description":"Sends multiple images or videos as a grouped album. Each item in the `album` array can have its own URL and caption.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","album"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"album":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"url":{"type":"string","example":"https://placehold.co/600x400.png"},"caption":{"type":"string","example":"Wamify Feature Overview"}}}}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/audio":{"post":{"summary":"Send Audio Message","tags":["Message Sends (Media)"],"description":"Sends an audio file from a URL as a voice or audio message.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","url"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"url":{"type":"string","example":"https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/document":{"post":{"summary":"Send Document Message","tags":["Message Sends (Media)"],"description":"Sends a document file from a URL (PDF, Word, Excel, etc.) with an optional caption.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","url"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"url":{"type":"string","example":"https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf"},"caption":{"type":"string","example":"Wamify API Documentation"}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/button":{"post":{"summary":"Send Button Message","tags":["Message Sends (Interactive)"],"description":"Sends an interactive message with action buttons (quick reply, URL, call, copy). Optionally attach an image, video, or document header.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","interactiveButtons"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"text":{"type":"string","description":"Body text for the button message","example":"Welcome to Wamify! Choose an option below:"},"caption":{"type":"string","description":"Caption text, used when sending button with media","example":"Wamify - High Performance Messaging"},"title":{"type":"string","description":"Title header for the button message","example":"Wamify Customer Portal"},"subtitle":{"type":"string","description":"Subtitle text","example":"Your gateway to seamless messaging"},"footer":{"type":"string","description":"Footer text displayed below the buttons","example":"Powered by Wamify"},"url":{"type":"string","description":"Media URL when sending button with image/video/document","example":"https://placehold.co/600x400.png"},"mediaType":{"type":"string","enum":["image","video","document"],"description":"Type of media attachment (image, video, or document)","example":"image"},"interactiveButtons":{"type":"array","minItems":1,"description":"Array of interactive buttons. Supports quick_reply, cta_url, cta_call, cta_copy, and address_message types.","items":{"type":"object","additionalProperties":false,"properties":{"name":{"type":"string","description":"Button type identifier","example":"quick_reply"},"buttonParamsJson":{"type":"string","description":"JSON string containing button parameters","example":"{\"display_text\":\"Get Started\",\"id\":\"btn_start\"}"}}},"example":[{"name":"quick_reply","buttonParamsJson":"{\"display_text\":\"Get Started\",\"id\":\"btn_start\"}"},{"name":"cta_url","buttonParamsJson":"{\"display_text\":\"Visit Website\",\"url\":\"https://wa.rezzaflamingo.com\"}"},{"name":"cta_call","buttonParamsJson":"{\"display_text\":\"Call Us\",\"phone_number\":\"+628123456789\"}"}]}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/list":{"post":{"summary":"Send List Message","tags":["Message Sends (Interactive)"],"description":"Sends an interactive list message with categorized rows that recipients can select from. Useful for menus, options, or service catalogs.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","text","buttonText","sections"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"text":{"type":"string","example":"Welcome to Wamify! Please choose a service:"},"title":{"type":"string","example":"Wamify Customer Portal"},"footer":{"type":"string","example":"24/7 Support: https://wa.rezzaflamingo.com"},"buttonText":{"type":"string","example":"Main Menu"},"sections":{"type":"array","example":[{"title":"Main Services","rows":[{"title":"Check Balance","description":"View your current account balance","id":"check_balance"},{"title":"Transfer","description":"Send money to other users","id":"transfer"}]},{"title":"Other Services","rows":[{"title":"Top Up Credit","description":"Recharge your phone credit","id":"top_up"},{"title":"Pay Bills","description":"Electricity, Water, and more","id":"pay_bills"},{"title":"Customer Service","description":"Contact our 24/7 support team","id":"cs_help"}]}],"items":{"type":"object","additionalProperties":false,"properties":{"title":{"type":"string","example":"Category A"},"rows":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"title":{"type":"string","example":"Item 1"},"description":{"type":"string","example":"Description for item 1"},"id":{"type":"string","example":"item-1"}}}}}}}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/location":{"post":{"summary":"Send Location Message","tags":["Message Sends (Basic)"],"description":"Sends a GPS location pin with optional name and address label.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","degreesLatitude","degreesLongitude"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"degreesLatitude":{"type":"number","example":-6.2088},"degreesLongitude":{"type":"number","example":106.8456},"locationName":{"type":"string","example":"RFC HQ"},"locationAddress":{"type":"string","example":"DKI Jakarta, Indonesia"}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/contact":{"post":{"summary":"Send Contact Message","tags":["Message Sends (Basic)"],"description":"Sends one or more vCard contacts. Each contact requires a `displayName` and a vCard string in standard VCARD 3.0 format.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","contacts"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"contacts":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"displayName":{"type":"string","example":"Wamify Support"},"vcard":{"type":"string","example":"BEGIN:VCARD\nVERSION:3.0\nFN:RFC\nTEL;type=CELL;type=VOICE;waid=628123456789:+62 812-3456-789\nEND:VCARD"}}}}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/event":{"post":{"summary":"Send Event Message","tags":["Message Sends (Basic)"],"description":"Sends a WhatsApp event/calendar invitation with name, description, location, start/end time, and optional call link.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","event"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"event":{"type":"object","additionalProperties":false,"properties":{"isCanceled":{"type":"boolean","example":false},"name":{"type":"string","example":"Wamify Update Webinar"},"description":{"type":"string","example":"Learn about the latest features and API improvements in Wamify."},"location":{"type":"object","additionalProperties":false,"example":{"degreesLatitude":-6.2088,"degreesLongitude":106.8456,"name":"RFC HQ"}},"call":{"type":"string","example":"audio"},"startTime":{"type":"number","example":1781800572},"endTime":{"type":"number","example":1781804172},"extraGuestsAllowed":{"type":"boolean","example":true}}}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/poll":{"post":{"summary":"Send Poll Message","tags":["Message Sends (Basic)"],"description":"Sends an interactive poll with a question and multiple answer options. Recipients can vote and results are tracked.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","poll"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"poll":{"type":"object","additionalProperties":false,"required":["name","values"],"properties":{"name":{"type":"string","example":"How would you rate your experience with Wamify?"},"values":{"type":"array","items":{"type":"string"},"minItems":2,"example":["Excellent","Good","Needs Improvement"]},"selectableCount":{"type":"number","default":1,"example":1},"toAnnouncementGroup":{"type":"boolean","default":false,"example":false}}}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/poll-result":{"post":{"summary":"Send Poll Result Message","tags":["Message Sends (Basic)"],"description":"Sends a summary of poll results showing vote counts per option.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","pollResult"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"pollResult":{"type":"object","additionalProperties":false,"required":["name","votes"],"properties":{"name":{"type":"string","example":"Best Wamify Feature?"},"votes":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"name":{"type":"string","example":"Bulk Messaging"},"voters":{"type":"array","items":{"type":"string"},"example":["628123456789@s.whatsapp.net"]}}}},"type":{"type":"string","enum":["creation","update"],"default":"creation","example":"creation"}},"example":{"name":"Best Wamify Feature?","votes":[{"name":"Bulk Messaging","voters":["628123456789@s.whatsapp.net"]},{"name":"Scheduled Messages","voters":["628987654321@s.whatsapp.net","628111222333@s.whatsapp.net"]},{"name":"Auto Reply","voters":[]}],"type":"creation"}}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/sticker":{"post":{"summary":"Send Sticker Message","tags":["Message Sends (Media)"],"description":"Sends a sticker from a direct URL to a `.webp` file.","requestBody":{"required":true,"content":{"application/json":{"schema":{"type":"object","additionalProperties":false,"required":["recipientPN","url"],"properties":{"recipientPN":{"type":"array","items":{"type":"string"},"minItems":1,"example":["628123456789","1122334455667788@g.us"]},"url":{"type":"string","description":"Direct URL to .webp file","example":"https://example.com/sticker.webp"}}}}}},"parameters":[{"schema":{"type":"string"},"in":"path","name":"sessionId","required":true}],"security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"results":{"type":"array","items":{"type":"object","additionalProperties":false,"properties":{"number":{"type":"string"},"success":{"type":"boolean"},"error":{"type":"string"}}}}}}}}}}}},"/api/v1/{sessionId}/messages/send/ptv"